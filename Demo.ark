    (207, 7,  7,  500.00),
    (208, 8,  3, 1100.00),
    (209, 9,  2, 1800.00),
    (210, 10, 6, 2500.00),
    (211, 11, 4,  650.00),
    (212, 12, 1, 1000.00);

SELECT * FROM patients;
SELECT * FROM doctors;
SELECT * FROM appointments;

-- Currently admitted patients
SELECT * FROM patients WHERE admitted == TRUE;

-- Senior patients (age over 60)
SELECT * FROM patients WHERE age > 60;

-- Younger patients (under 40)
SELECT * FROM patients WHERE age < 40;

-- Sort patients by age
SELECT * FROM patients ORDER BY age ASC;

-- Available doctors only
SELECT * FROM doctors WHERE available == TRUE;

-- Find cardiology doctor
SELECT * FROM doctors WHERE specialty LIKE "Cardio%";

-- Appointments with high fee
SELECT * FROM appointments WHERE fee > 1000.0;

-- Sort appointments by fee
SELECT * FROM appointments ORDER BY fee DESC;

-- Patient name contains "Sharma"
SELECT * FROM patients WHERE name LIKE "%Sharma%";

-- Update: discharge a patient
UPDATE patients SET admitted = FALSE WHERE patient_id == 4;

-- Update: doctor becomes available
UPDATE doctors SET available = TRUE WHERE doctor_id == 2;

-- Appointment fee update
UPDATE appointments SET fee = 1600.00 WHERE appt_id == 201;

-- Check updates
SELECT * FROM patients WHERE patient_id == 4;
SELECT * FROM doctors WHERE doctor_id == 2;

-- Remove old appointment
DELETE FROM appointments WHERE fee < 510.0;

SELECT * FROM appointments;

SAVE;


-- ============================================================
--   SECTION 6: LIBRARY DATABASE
-- ============================================================

USE library;

CREATE TABLE books (
    book_id    INT,
    title      STRING,
    author     STRING,
    price      DOUBLE,
    available  BOOL
);

CREATE TABLE members (
    member_id  INT,
    name       STRING,
    active     BOOL,
    fine       DOUBLE
);

CREATE TABLE borrows (
    borrow_id  INT,
    member_id  INT,
    book_id    INT,
    returned   BOOL
);

SHOW TABLES;
SHOW COLUMNS FROM books;
SHOW COLUMNS FROM members;

-- Insert books
INSERT INTO books VALUES
    (1,  "Clean Code",              "Robert Martin",   650.00, TRUE),
    (2,  "The Pragmatic Programmer","Hunt & Thomas",   799.00, TRUE),
    (3,  "Design Patterns",         "Gang of Four",    950.00, FALSE),
    (4,  "Introduction to Algo",    "Cormen et al",   1100.00, TRUE),
    (5,  "Computer Networks",       "Tanenbaum",       850.00, FALSE),
    (6,  "Operating System Concepts","Silberschatz",   750.00, TRUE),
    (7,  "Database Management",     "Ramakrishnan",    880.00, TRUE),
    (8,  "Artificial Intelligence", "Russell & Norvig",1200.00,TRUE),
    (9,  "Python Crash Course",     "Eric Matthes",    550.00, FALSE),
    (10, "You Dont Know JS",        "Kyle Simpson",    499.00, TRUE),
    (11, "The Mythical Man Month",  "Fred Brooks",     420.00, TRUE),
    (12, "Code Complete",           "Steve McConnell", 720.00, FALSE);

-- Insert members
INSERT INTO members VALUES
    (1, "Aisha",   TRUE,   0.00),
    (2, "Bharat",  TRUE,  50.00),
    (3, "Chitra",  FALSE, 150.00),
    (4, "Dev",     TRUE,   0.00),
    (5, "Esha",    TRUE,  25.00),
    (6, "Farhan",  FALSE, 200.00),
    (7, "Gauri",   TRUE,   0.00),
    (8, "Himesh",  TRUE,  75.00);

-- Insert borrows
INSERT INTO borrows VALUES
    (301, 1, 1,  TRUE),
    (302, 2, 4,  FALSE),
    (303, 3, 5,  FALSE),
    (304, 4, 8,  TRUE),
    (305, 5, 2,  FALSE),
    (306, 6, 9,  FALSE),
    (307, 7, 3,  TRUE),
    (308, 8, 6,  FALSE),
    (309, 1, 7,  FALSE),
    (310, 4, 10, TRUE),
    (311, 5, 12, FALSE),
    (312, 2, 11, TRUE);

SELECT * FROM books;
SELECT * FROM members;
SELECT * FROM borrows;

-- Available books
SELECT * FROM books WHERE available == TRUE;

-- Unavailable books
SELECT * FROM books WHERE available == FALSE;

-- Expensive books (over 900)
SELECT title, price FROM books WHERE price > 900.00;

-- Affordable books (under 600)
SELECT title, price FROM books WHERE price < 600.00;

-- Sort books by price
SELECT * FROM books ORDER BY price ASC;
SELECT * FROM books ORDER BY price DESC;

-- Books by author containing "et"
SELECT * FROM books WHERE author LIKE "%et%";

-- Book title starts with "C"
SELECT * FROM books WHERE title LIKE "C%";

-- Active members
SELECT * FROM members WHERE active == TRUE;

-- Members with fines
SELECT * FROM members WHERE fine > 0.0;

-- Members with high fine
SELECT * FROM members WHERE fine > 100.0;

-- Sort members by fine
SELECT * FROM members ORDER BY fine DESC;

-- Unreturned borrows
SELECT * FROM borrows WHERE returned == FALSE;

-- Returned borrows
SELECT * FROM borrows WHERE returned == TRUE;

-- Update: book returned so mark available
UPDATE books SET available = TRUE WHERE book_id == 5;

-- Update: add fine to a member
UPDATE members SET fine = 250.00 WHERE member_id == 6;

-- Deactivate a member
UPDATE members SET active = FALSE WHERE name LIKE "Bharat%";

-- Check updates
SELECT * FROM books WHERE book_id == 5;
SELECT * FROM members;

-- Clear fines for all active members with small fines
DELETE FROM members WHERE fine < 30.0 AND active == TRUE LIMIT 1;

-- Update: mark borrow returned
UPDATE borrows SET returned = TRUE WHERE borrow_id == 302;

SELECT * FROM borrows;
SELECT * FROM members;

SAVE;


-- ============================================================
--   SECTION 7: SAVE AND LOAD VERIFICATION
-- ============================================================

-- Reload school and verify
USE school;
LOAD;
SELECT * FROM students;
SELECT * FROM courses;
SELECT * FROM enrollments;

-- Reload store and verify
USE store;
LOAD;
SELECT * FROM products;
SELECT * FROM customers;
SELECT * FROM orders;

-- Reload hospital and verify
USE hospital;
LOAD;
SELECT * FROM patients;
SELECT * FROM doctors;
SELECT * FROM appointments;

-- Reload library and verify
USE library;
LOAD;
SELECT * FROM books;
SELECT * FROM members;
SELECT * FROM borrows;


-- ============================================================
--   SECTION 8: CLEANUP - DROP TABLES AND DATABASES
-- ============================================================

-- Drop tables from library
USE library;
DROP TABLE borrows;
SHOW TABLES;
DROP TABLE members;
SHOW TABLES;

-- Drop library database
DROP DATABASE library;
SHOW DATABASES;

-- Drop tables from hospital
USE hospital;
DROP TABLE appointments;
DROP TABLE doctors;
SHOW TABLES;

-- Drop hospital database
DROP DATABASE hospital;
SHOW DATABASES;

-- Drop a table from store
USE store;
DROP TABLE orders;
SHOW TABLES;

-- Drop store database
DROP DATABASE store;
SHOW DATABASES;

-- Drop a table from school
USE school;
DROP TABLE enrollments;
SHOW TABLES;

-- Drop school database
DROP DATABASE school;

-- Nothing left
SHOW DATABASES;


