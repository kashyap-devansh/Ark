    (7,  "USB Hub",        899.00, TRUE),
    (8,  "SSD 1TB",       6500.00, TRUE),
    (9,  "Gaming Chair", 15000.00, TRUE),
    (10, "Desk Lamp",      450.00, TRUE),
    (11, "Printer",       8999.00, FALSE),
    (12, "Tablet",       25000.00, TRUE);

-- Insert customers
INSERT INTO customers VALUES
    (1, "Amit",    TRUE,  150000.00),
    (2, "Neha",    FALSE,  25000.00),
    (3, "Raj",     TRUE,  200000.00),
    (4, "Divya",   FALSE,  12000.00),
    (5, "Suresh",  TRUE,  500000.00),
    (6, "Pooja",   FALSE,   8500.00),
    (7, "Kiran",   TRUE,  300000.00),
    (8, "Manish",  FALSE,  45000.00);

-- Insert orders
INSERT INTO orders VALUES
    (1001, 1, 1,  2, 110001.98),
    (1002, 2, 2,  5,   3997.50),
    (1003, 3, 3,  3,   3897.00),
    (1004, 5, 5,  1,   3499.00),
    (1005, 1, 1,  1,  55000.99),
    (1006, 7, 8,  2,  13000.00),
    (1007, 3, 9,  1,  15000.00),
    (1008, 4, 10, 3,   1350.00),
    (1009, 6, 2,  1,    799.50),
    (1010, 8, 12, 1,  25000.00),
    (1011, 5, 1,  3, 165002.97),
    (1012, 7, 4,  1,  18000.00);

-- See all data
SELECT * FROM products;
SELECT * FROM customers;
SELECT * FROM orders;

-- In-stock products only
SELECT * FROM products WHERE in_stock == TRUE;

-- Out-of-stock products
SELECT * FROM products WHERE in_stock == FALSE;

-- Expensive products (over 10000)
SELECT name, price FROM products WHERE price > 10000.0;

-- Affordable products (under 1000)
SELECT name, price FROM products WHERE price < 1000.0;

-- Sort products by price low to high
SELECT * FROM products ORDER BY price ASC;

-- Sort products by price high to low
SELECT * FROM products ORDER BY price DESC;

-- Products whose name ends with "p"
SELECT * FROM products WHERE name LIKE "%p";

-- Products whose name starts with "M"
SELECT * FROM products WHERE name LIKE "M%";

-- Premium customers
SELECT * FROM customers WHERE is_premium == TRUE;

-- Customers with high balance
SELECT * FROM customers WHERE balance > 100000.0;

-- Sort customers by balance
SELECT * FROM customers ORDER BY balance DESC;

-- Big orders (total over 50000)
SELECT * FROM orders WHERE total > 50000.0;

-- Orders with quantity more than 1
SELECT * FROM orders WHERE quantity > 1;

-- Update: keyboard went out of stock
UPDATE products SET in_stock = FALSE WHERE product_id == 3;

-- Update: monitor price reduced
UPDATE products SET price = 17500.00 WHERE product_id == 4;

-- Upgrade a customer to premium
UPDATE customers SET is_premium = TRUE WHERE name LIKE "Neha%";

-- Verify updates
SELECT * FROM products;
SELECT * FROM customers WHERE name LIKE "Neha%";

-- Delete small orders
DELETE FROM orders WHERE total < 1000.0;

-- Check orders
SELECT * FROM orders;

SAVE;


-- ============================================================
--   SECTION 5: HOSPITAL DATABASE
-- ============================================================

USE hospital;

CREATE TABLE patients (
    patient_id  INT,
    name        STRING,
    age         INT,
    admitted    BOOL
);

CREATE TABLE doctors (
    doctor_id   INT,
    name        STRING,
    specialty   STRING,
    available   BOOL
);

CREATE TABLE appointments (
    appt_id     INT,
    patient_id  INT,
    doctor_id   INT,
    fee         DOUBLE
);

SHOW TABLES;
SHOW COLUMNS FROM patients;
SHOW COLUMNS FROM doctors;

-- Insert patients
INSERT INTO patients VALUES
    (1,  "Ravi Kumar",   34, TRUE),
