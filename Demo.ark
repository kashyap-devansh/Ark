-- ============================================================
--   ARK DATABASE ENGINE - FULL DEMO
-- ============================================================


-- ============================================================
--   SECTION 1: START FRESH
-- ============================================================

SHOW DATABASES;


-- ============================================================
--   SECTION 2: CREATE ALL DATABASES
-- ============================================================

CREATE DATABASE school;
CREATE DATABASE store;
CREATE DATABASE hospital;
CREATE DATABASE library;

SHOW DATABASES;


-- ============================================================
--   SECTION 3: SCHOOL DATABASE
-- ============================================================

USE school;

-- Create tables
CREATE TABLE students (
    id       INT,
    name     STRING,
    gpa      DOUBLE,
    active   BOOL
);

CREATE TABLE courses (
    course_id   INT,
    title       STRING,
    credits     INT,
    is_elective BOOL
);

CREATE TABLE enrollments (
    enrollment_id  INT,
    student_id     INT,
    course_id      INT,
    grade          DOUBLE
);

SHOW TABLES;
SHOW COLUMNS FROM students;
SHOW COLUMNS FROM courses;
SHOW COLUMNS FROM enrollments;

-- Insert students
INSERT INTO students VALUES
    (1,  "Devansh",   9.2, TRUE),
    (2,  "Rohan",     8.7, TRUE),
    (3,  "Priya",     9.5, TRUE),
    (4,  "Arjun",     7.1, FALSE),
    (5,  "Sneha",     8.3, TRUE),
    (6,  "Vikram",    6.9, FALSE),
    (7,  "Ananya",    9.0, TRUE),
    (8,  "Kabir",     7.8, TRUE),
    (9,  "Meera",     8.1, TRUE),
    (10, "Siddharth", 6.5, FALSE),
    (11, "Tanvi",     9.3, TRUE),
    (12, "Rahul",     7.4, TRUE);

-- Insert courses
INSERT INTO courses VALUES
    (101, "Data Structures",   4, FALSE),
    (102, "Database Systems",  3, FALSE),
    (103, "Web Development",   3, TRUE),
    (104, "Machine Learning",  4, TRUE),
    (105, "Operating Systems", 4, FALSE),
    (106, "Computer Networks", 3, FALSE),
    (107, "Cloud Computing",   3, TRUE),
    (108, "Cybersecurity",     4, TRUE);

-- Insert enrollments
INSERT INTO enrollments VALUES
    (1,  1,  101, 9.1),
    (2,  1,  102, 8.8),
    (3,  2,  101, 8.5),
    (4,  2,  104, 9.0),
    (5,  3,  102, 9.4),
    (6,  3,  105, 9.2),
    (7,  4,  103, 7.0),
    (8,  5,  107, 8.6),
    (9,  6,  108, 6.8),
    (10, 7,  104, 9.1),
    (11, 8,  106, 7.9),
    (12, 9,  101, 8.2),
    (13, 10, 103, 6.4),
    (14, 11, 102, 9.5),
    (15, 12, 108, 7.3);

-- See all data
SELECT * FROM students;
SELECT * FROM courses;
SELECT * FROM enrollments;

-- Only specific columns
SELECT name, gpa FROM students;
SELECT title, credits FROM courses;

-- Active students only
SELECT * FROM students WHERE active == TRUE;

-- Inactive students
SELECT * FROM students WHERE active == FALSE;

-- High GPA students
SELECT * FROM students WHERE gpa > 9.0;

-- Students with GPA between 8 and 9
SELECT * FROM students WHERE gpa >= 8.0 AND gpa < 9.0;

-- Low GPA or inactive
SELECT * FROM students WHERE gpa < 7.5 OR active == FALSE;

-- Sort by GPA lowest to highest
SELECT * FROM students ORDER BY gpa ASC;

-- Sort by GPA highest to lowest
SELECT * FROM students ORDER BY gpa DESC;

-- Name starts with "S"
SELECT * FROM students WHERE name LIKE "S%";

-- Name contains "an"
SELECT * FROM students WHERE name LIKE "%an%";

-- Name ends with "a"
SELECT * FROM students WHERE name LIKE "%a";

-- Elective courses only
SELECT * FROM courses WHERE is_elective == TRUE;

-- Courses with 4 credits
SELECT * FROM courses WHERE credits == 4;

-- Sort courses by credits
SELECT * FROM courses ORDER BY credits ASC;

-- High grade enrollments
SELECT * FROM enrollments WHERE grade > 9.0;

-- Update one student's GPA
UPDATE students SET gpa = 7.8 WHERE name LIKE "%jun%";

-- Update multiple columns for one student
UPDATE students SET gpa = 9.8, active = TRUE WHERE id == 10;

-- Make all 3-credit courses into 4-credit
UPDATE courses SET credits = 4 WHERE credits == 3 AND is_elective == FALSE;

-- Check updates
SELECT * FROM students WHERE id == 10;
SELECT * FROM students;
SELECT * FROM courses;

-- Delete one inactive student
DELETE FROM students WHERE active == FALSE LIMIT 1;

-- Delete low-grade enrollments
DELETE FROM enrollments WHERE grade < 7.0;

-- Check after deletes
SELECT * FROM students;
SELECT * FROM enrollments;

SAVE;


-- ============================================================
--   SECTION 4: STORE DATABASE
-- ============================================================

USE store;

CREATE TABLE products (
    product_id  INT,
    name        STRING,
    price       DOUBLE,
    in_stock    BOOL
);

CREATE TABLE customers (
    customer_id  INT,
    name         STRING,
    is_premium   BOOL,
    balance      DOUBLE
);

CREATE TABLE orders (
    order_id    INT,
    customer_id INT,
    product_id  INT,
    quantity    INT,
    total       DOUBLE
);

SHOW TABLES;
SHOW COLUMNS FROM products;
SHOW COLUMNS FROM customers;
SHOW COLUMNS FROM orders;

-- Insert products
