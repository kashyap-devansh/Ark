    (5,  "Harish Rao",   29, FALSE),
    (6,  "Rekha Singh",  71, TRUE),
    (7,  "Mohan Das",    40, TRUE),
    (8,  "Lakshmi Nair", 55, FALSE),
    (9,  "Vijay Patil",  38, TRUE),
    (10, "Kamla Verma",  67, TRUE),
    (11, "Deepak Joshi", 50, FALSE),
    (12, "Usha Mehta",   43, TRUE);

-- Insert doctors
INSERT INTO doctors VALUES
    (1, "Dr. Kapoor",    "Cardiology",    TRUE),
