-- Create and use database
CREATE DATABASE nulldb;
USE nulldb;

-- Create table
CREATE TABLE employees (
    id INT,
    name STRING,
    salary DOUBLE,
    age INT
);

-- Insert data (with NULL)
INSERT INTO employees VALUES
(1, "Alice", 50000.0, 25),
(2, "Bob", 60000.0, 30),
(3, "Charlie", 70000.0, 35),
(4, "David", 80000.0, 40),
(5, "Eve", NULL, 28);

TRUNCATE TABLE employees;

SELECT * FROM employees;