CREATE DATABASE testdb;
USE testdb;

CREATE TABLE users (
    id INT,
    name STRING,
    age INT,
    score DOUBLE,
    active BOOL
);

INSERT INTO users VALUES
    (1, "Alice", 30, 9.5, true),
    (2, "Bob", 25, 7.2, false),
    (4, "David", 28, 6.5, true),
    (5, "Aaron", 22, 9.1, false),
    (3, "Charlie", 35, 8.8, true);

SELECT * FROM users ORDER BY id;